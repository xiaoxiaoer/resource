{
  "_comment": "车场资料必填字段定义，completeness-check skill 引用此配置。字段范围以 prompts/audit_field_rules.md 为准。",

  "common": {
    "_comment": "两种业务共有必填字段（项目基本信息表）",
    "fields": [
      {
        "key": "company_name",
        "label": "合作客户主体",
        "required": true,
        "type": "string"
      },
      {
        "key": "property_type",
        "label": "是否产权方/承包方",
        "required": true,
        "type": "enum",
        "options": ["产权方", "承包方"]
      },
      {
        "key": "contract_expire_date",
        "label": "承包到期时间",
        "required": "property_type == '承包方'",
        "type": "date"
      },
      {
        "key": "contract_months",
        "label": "合同有效年限（月）",
        "required": true,
        "type": "integer",
        "min": 1
      },
      {
        "key": "has_own_channel",
        "label": "是否存在自有小程序/ETC支付渠道",
        "required": true,
        "type": "enum",
        "options": ["是", "否"]
      },
      {
        "key": "car_park_name",
        "label": "车场名称",
        "required": true,
        "type": "string"
      },
      {
        "key": "monthly_temp_income",
        "label": "车场月均临停收入",
        "required": true,
        "type": "number"
      },
      {
        "key": "monthly_ticket_income",
        "label": "车场月均月票收入",
        "required": "involves_ticket_exchange == true",
        "type": "number"
      }
    ]
  },

  "parking_voucher": {
    "_comment": "停车券业务测算工具表必填字段（仅 10 个，参见 audit_field_rules.md）",
    "fields": [
      {
        "key": "equipment_service_amount",
        "label": "设备和服务置换金额",
        "required": true,
        "type": "number"
      },
      {
        "key": "cash_purchase_amount",
        "label": "现金采买金额",
        "required": true,
        "type": "number"
      },
      {
        "key": "payment_method",
        "label": "付款方式",
        "required": false,
        "type": "string",
        "note": "有值时展示，无值不强制"
      },
      {
        "key": "business_fee",
        "label": "业务费",
        "required": false,
        "type": "number",
        "note": "有则需运营人工评估"
      },
      {
        "key": "discount_rate",
        "label": "采买折扣",
        "required": true,
        "type": "number"
      },
      {
        "key": "contract_months",
        "label": "合同有效年限（月）",
        "required": true,
        "type": "integer",
        "min": 1
      },
      {
        "key": "voucher_consume_months",
        "label": "券消耗年限（月）",
        "required": true,
        "type": "integer",
        "min": 1
      },
      {
        "key": "vat_rate",
        "label": "增值税普通发票",
        "required": true,
        "type": "number"
      },
      {
        "key": "monthly_temp_income",
        "label": "车场月均临停收入",
        "required": true,
        "type": "number"
      },
      {
        "key": "monthly_ticket_income",
        "label": "车场月均月租收入",
        "required": true,
        "type": "number",
        "note": "BEM月票数据全为0时跳过对比验证"
      }
    ]
  },

  "spot_exchange": {
    "_comment": "车位置换业务测算工具表必填字段（仅 6 个，参见 audit_field_rules.md）",
    "fields": [
      {
        "key": "equipment_service_amount",
        "label": "设备和服务置换金额",
        "required": true,
        "type": "number",
        "note": "应为CRM报价单总金额"
      },
      {
        "key": "vat_rate",
        "label": "增值税专用发票",
        "required": true,
        "type": "number"
      },
      {
        "key": "external_monthly_card_fee",
        "label": "对外办理的月卡费用",
        "required": true,
        "type": "number",
        "note": "取BEM中非内部/VIP的月票套餐价格"
      },
      {
        "key": "replacement_spaces",
        "label": "置换车位数",
        "required": true,
        "type": "integer",
        "min": 1
      },
      {
        "key": "profit_share_ratio",
        "label": "回本后甲方分润比例",
        "required": true,
        "type": "number"
      },
      {
        "key": "contract_months",
        "label": "合同有效年限",
        "required": true,
        "type": "integer",
        "min": 36,
        "note": "车位置换业务要求合同有效年限≥3年（36个月）"
      }
    ]
  }
}
