{
  "_comment": "车场资料必填字段定义，completeness-check skill 引用此配置",

  "common": {
    "_comment": "两种业务共有必填字段",
    "fields": [
      {
        "key": "company_name",
        "label": "合作客户主体",
        "required": true,
        "type": "string"
      },
      {
        "key": "property_type",
        "label": "是否产权方/承包方",
        "required": true,
        "type": "enum",
        "options": ["产权方", "承包方"]
      },
      {
        "key": "contract_expire_date",
        "label": "承包到期时间",
        "required": "property_type == '承包方'",
        "type": "date"
      },
      {
        "key": "contract_months",
        "label": "合同有效年限（月）",
        "required": true,
        "type": "integer",
        "min": 1
      },
      {
        "key": "has_own_channel",
        "label": "是否存在自有小程序/ETC支付渠道",
        "required": true,
        "type": "enum",
        "options": ["是", "否"]
      },
      {
        "key": "car_park_name",
        "label": "车场名称",
        "required": true,
        "type": "string"
      },
      {
        "key": "monthly_temp_income",
        "label": "车场月均临停收入",
        "required": true,
        "type": "number"
      },
      {
        "key": "monthly_ticket_income",
        "label": "车场月均月票收入",
        "required": "involves_ticket_exchange == true",
        "type": "number"
      }
    ]
  },

  "parking_voucher": {
    "_comment": "停车券业务额外必填字段",
    "fields": [
      {
        "key": "voucher_consume_months",
        "label": "券消耗年限（月）",
        "required": true,
        "type": "integer",
        "min": 1
      },
      {
        "key": "voucher_monthly_consume",
        "label": "停车券月均消耗额度",
        "required": true,
        "type": "number"
      },
      {
        "key": "voucher_total_value",
        "label": "停车券总价值",
        "required": true,
        "type": "number"
      },
      {
        "key": "project_gross_profit",
        "label": "项目整体毛利",
        "required": true,
        "type": "number"
      },
      {
        "key": "installment_deduction",
        "label": "分期代扣",
        "required": false,
        "type": "number",
        "note": "有则需运营人工评估"
      },
      {
        "key": "crm_service_fee",
        "label": "CRM专项服务费",
        "required": false,
        "type": "number",
        "note": "与业务费不会同时共存"
      },
      {
        "key": "business_fee",
        "label": "业务费",
        "required": false,
        "type": "number",
        "note": "与CRM专项服务费不会同时共存"
      }
    ]
  },

  "spot_exchange": {
    "_comment": "车位置换业务额外必填字段",
    "fields": [
      {
        "key": "equipment_service_amount",
        "label": "设备服务置换金额",
        "required": true,
        "type": "number",
        "note": "应为CRM报价单总金额"
      },
      {
        "key": "crm_settlement_price",
        "label": "CRM结算价",
        "required": true,
        "type": "number"
      },
      {
        "key": "external_monthly_card_fee",
        "label": "对外办理的月卡费用",
        "required": true,
        "type": "number",
        "note": "取BEM中非内部/VIP的月票套餐价格"
      },
      {
        "key": "allow_posting_materials",
        "label": "是否允许张贴物料",
        "required": true,
        "type": "enum",
        "options": ["是", "否"]
      },
      {
        "key": "contract_months_min",
        "label": "合同有效年限最低要求",
        "required": true,
        "type": "integer",
        "min": 36,
        "note": "车位置换业务要求合同有效年限≥3年（36个月）"
      }
    ]
  }
}
