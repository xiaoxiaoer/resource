# BEM 运营管理平台
BEM_BASE_URL=https://bemaomp.yidianting.xin
BEM_USERNAME=your_username
BEM_PASSWORD=your_password

# LLM 配置（OpenAI 兼容接口）
# DeepSeek: base_url=https://api.deepseek.com, model=deepseek-chat
# 智谱GLM: base_url=https://open.bigmodel.cn/api/paas/v4, model=glm-4
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 审核模式总开关
# false（默认）：纯程序化校验，BEM/企查查仍调用作为数据采集
# true：在程序化校验基础上叠加 LLM 增强分析
# 前端页面也可临时覆盖此默认值
ENABLE_LLM_AUDIT=false
